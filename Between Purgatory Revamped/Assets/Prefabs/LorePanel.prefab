  m_FontData:
    m_Font: {fileID: 12800000, guid: a0bdb16889ee11c44b0783c2bc51a41c, type: 3}
    m_FontSize: 35
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 50
    m_Alignment: 1
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "Second stage of conversion.  Reapers dawn lost human souls on its back
    as a reminder of the lives they have taken.  As the body continues to mangle
    itself, 4 small but sharp mandibles sprout out of its back.  Despite their threatening
    appearance, the mandibles are not used for combat but rather to feed off of the
    body of their dead prey.  They also have the ability to conjure up and fire magma
    projectiles from its hands.  These deadly foes remain the most trusted of Aletheia's
    spawn, often guarding her keep and leading the smaller scavengers.  It can take
    5-7 years before they transition to the final stage.\r"
