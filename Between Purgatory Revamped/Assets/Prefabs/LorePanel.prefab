  m_FontData:
    m_Font: {fileID: 12800000, guid: a0bdb16889ee11c44b0783c2bc51a41c, type: 3}
    m_FontSize: 30
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 50
    m_Alignment: 1
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "Why you are here: You have been placed in purgatory after your death in
    a battle between two kingdoms with hell deeming you too virtuous for eternal
    suffering, but heaven deeming you too sinful for eternal bliss.  They leave it
    up to Aletheia\u2019s trials to decide your fate.  However, because of the god\u2019s
    distrust in Aletheia, they infuse earthly weapons with godlike power to present
    the possibility of defeating the purgatorial god.  An opportunity no other human
    has received up to this point.  No matter how hard you have to work for it, no
    matter what the side effects may be for killing a god, freedom will be yours."
